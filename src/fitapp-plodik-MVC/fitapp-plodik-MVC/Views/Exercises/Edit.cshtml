@model fitapp_plodik_MVC.Entities.Exercise

@{
    ViewData["Title"] = "Upravit cvik";
}

<style>
    .fit-page-title {
        font-family: 'Bebas Neue', sans-serif;
        letter-spacing: 2px;
        font-size: 2.3rem;
        margin-bottom: 0;
    }

    .fit-box {
        background: rgba(18, 18, 18, 0.92);
        border: 1px solid rgba(255,255,255,0.10);
        border-radius: 22px;
        padding: 24px;
        backdrop-filter: blur(10px);
        box-shadow: 0 0 35px rgba(34, 211, 238, 0.08);
    }

    .fit-label {
        font-weight: 700;
        color: rgba(255,255,255,0.85);
        margin-bottom: 6px;
    }

    .fit-input {
        background: rgba(0,0,0,0.45) !important;
        border: 1px solid rgba(255,255,255,0.12) !important;
        color: #fff !important;
        border-radius: 14px !important;
        padding: 10px 12px !important;
    }

    .fit-preview {
        margin-top: 12px;
        max-width: 220px;
        border-radius: 14px;
    }

    .fit-btn-save {
        background: rgba(255, 193, 7, 0.14);
        border: 1px solid rgba(255, 193, 7, 0.35);
        color: rgba(255, 193, 7, 0.95);
        font-weight: 800;
        border-radius: 14px;
        padding: 10px 18px;
    }

    .fit-btn-back {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.85);
        font-weight: 700;
        border-radius: 14px;
        padding: 10px 18px;
        text-decoration: none;
    }
</style>

<div class="fit-box">

    <h2 class="fit-page-title">Upravit cvik</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageUrl" />

        <div class="mb-3">
            <label class="fit-label">Název</label>
            <input asp-for="Name" class="form-control fit-input" />
        </div>

        <div class="mb-3">
            <label class="fit-label">Partie</label>
            <input asp-for="MuscleGroup" class="form-control fit-input" />
        </div>

        <div class="mb-3">
            <label class="fit-label">Popis</label>
            <textarea asp-for="Description" rows="4" class="form-control fit-input"></textarea>
        </div>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="text-center">
                <img src="@Model.ImageUrl" class="fit-preview" />
            </div>
        }

        <div class="mb-3">
            <label class="fit-label">Změnit obrázek</label>
            <input type="file" name="imageFile" class="form-control fit-input" />
        </div>

        <div class="mb-4">
            <label class="fit-label">Stroj</label>
            <select asp-for="MachineId" class="form-control fit-input" asp-items="ViewBag.MachineId">
                <option value="">-- bez stroje --</option>
            </select>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="fit-btn-save">Uložit</button>
            <a asp-action="Index" class="fit-btn-back">Zpět</a>
        </div>

    </form>

</div>